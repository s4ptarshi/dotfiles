      {
        "key": "Ctrl+Plus",
        "desc": "Increase font size",
        "action": "Increase font size",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Minus",
        "desc": "Decrease font size",
        "action": "Decrease font size",
        "source": "kitty"
      },
      {
        "key": "Ctrl+0",
