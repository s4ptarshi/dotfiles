{
  "title": "Kitty Keybinds",
  "provider": "kitty",
  "binds": {
    "Scrolling": [
      { "key": "Page_Up", "desc": "Scroll page up", "action": "Scroll page up", "source": "kitty" },
      { "key": "Page_Down", "desc": "Scroll page down", "action": "Scroll page down", "source": "kitty" },
      { "key": "C+S+Page_Up", "desc": "Scroll line up", "action": "Scroll line up", "source": "kitty" },
