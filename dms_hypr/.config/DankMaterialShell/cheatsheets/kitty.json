        "action": "View last command",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+B",
        "desc": "Open broadcast kitten",
        "action": "Open broadcast kitten",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+U",
        "desc": "Unicode input",
        "action": "Unicode input",
        "source": "kitty"
      }
