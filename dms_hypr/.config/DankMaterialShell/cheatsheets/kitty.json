    "System and Config": [
      {
        "key": "Ctrl+Alt+R",
        "desc": "Reload config",
        "action": "Reload config",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Alt+Comma",
        "desc": "Edit config file",
        "action": "Edit config file",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Delete",
