{
  "title": "Kitty Keybinds",
  "provider": "kitty",
  "binds": {
    "Scrolling": [
      {
        "key": "Page_Up",
        "desc": "k: Scroll page up",
        "subcat": "Page"
      },
      {
        "key": "Page_Down",
        "desc": "k: Scroll page down",
        "subcat": "Page"
      },
      {
        "key": "Ctrl+Shift+Page_Up",
        "desc": "k: Scroll line up",
        "subcat": "Line"
      },
      {
        "key": "Ctrl+Shift+Page_Down",
        "desc": "k: Scroll line down",
        "subcat": "Line"
      },
      {
        "key": "Ctrl+Shift+Home",
        "desc": "k: Scroll to top",
        "subcat": "Extremes"
      },
      {
        "key": "Ctrl+Shift+End",
        "desc": "k: Scroll to bottom",
        "subcat": "Extremes"
      },
      {
        "key": "Ctrl+Alt+Home",
        "desc": "k: Scroll to previous prompt",
        "subcat": "Prompts"
      },
      {
        "key": "Ctrl+Alt+End",
        "desc": "k: Scroll to next prompt",
        "subcat": "Prompts"
      }
    ],
    "Tabs Management": [
      {
        "key": "Ctrl+T",
        "desc": "k: New tab",
        "subcat": "Creation & Deletion"
      },
      {
        "key": "Ctrl+W",
        "desc": "k: Close tab",
        "subcat": "Creation & Deletion"
      },
      {
        "key": "Ctrl+Shift+N",
        "desc": "k: New tab with current directory",
        "subcat": "Creation & Deletion"
      },
      {
        "key": "Ctrl+Tab",
        "desc": "k: Next tab",
        "subcat": "Navigation"
      },
      {
        "key": "Ctrl+Shift+Tab",
        "desc": "k: Previous tab",
        "subcat": "Navigation"
      },
      {
        "key": "Alt+1...0",
        "desc": "k: Go to specific tab index",
        "subcat": "Navigation"
      },
      {
        "key": "Ctrl+Shift+Page_Down",
        "desc": "k: Move tab forward",
        "subcat": "Arrangement"
      },
      {
        "key": "Ctrl+Shift+Page_Up",
        "desc": "k: Move tab backward",
        "subcat": "Arrangement"
      }
    ],
    "Windows Management": [
      {
        "key": "Ctrl+Shift+Enter",
        "desc": "k: New window with current directory",
        "subcat": "Creation & Deletion"
      },
      {
        "key": "Alt+\\",
        "desc": "k: New vertical split",
        "subcat": "Creation & Deletion"
      },
      {
        "key": "Alt+-",
        "desc": "k: New horizontal split",
        "subcat": "Creation & Deletion"
      },
      {
        "key": "Ctrl+Shift+Q",
        "desc": "k: Close window",
        "subcat": "Creation & Deletion"
      },
      {
        "key": "Alt+H/J/K/L",
        "desc": "k: Navigate between panes (Vim keys)",
        "subcat": "Navigation"
      },
      {
        "key": "Ctrl+1...0",
        "desc": "k: Focus specific window",
        "subcat": "Navigation"
      },
      {
        "key": "Alt+Shift+H/J/K/L",
        "desc": "k: Resize panes",
        "subcat": "Arrangement"
      },
      {
        "key": "Ctrl+Shift+F",
        "desc": "k: Next layout",
        "subcat": "Layout"
      },
      {
        "key": "Ctrl+Shift+Space",
        "desc": "k: Toggle stack layout (Zoom)",
        "subcat": "Layout"
      }
    ],
    "Appearance & Fonts": [
      {
        "key": "Ctrl+Plus / Ctrl+Equal",
        "desc": "k: Increase font size",
        "subcat": "Font"
      },
      {
        "key": "Ctrl+Minus",
        "desc": "k: Decrease font size",
        "subcat": "Font"
      },
      {
        "key": "Ctrl+0",
        "desc": "k: Reset font size",
        "subcat": "Font"
      },
      {
        "key": "F11",
        "desc": "k: Toggle fullscreen",
        "subcat": "Window State"
      }
    ],
    "Shell & Plugins": [
      {
        "key": "Ctrl+Shift+H",
        "desc": "k: Browse scrollback in nvim (Plugin)",
        "subcat": "kitty-scrollback"
      },
      {
        "key": "Ctrl+Shift+G",
        "desc": "k: View last command output in nvim",
        "subcat": "kitty-scrollback"
      },
      {
        "key": "Ctrl+Shift+B",
        "desc": "k: Open broadcast kitten",
        "subcat": "Utility"
      },
      {
        "key": "Ctrl+Shift+U",
        "desc": "k: Unicode input",
        "subcat": "Utility"
      }
    ],
    "System & Config": [
      {
        "key": "Ctrl+Alt+R",
        "desc": "k: Reload kitty.conf",
        "subcat": "Configuration"
      },
      {
        "key": "Ctrl+Shift+Alt+,",
        "desc": "k: Edit config file",
        "subcat": "Configuration"
      },
      {
        "key": "Ctrl+Shift+Delete",
        "desc": "k: Clear terminal and reset",
        "subcat": "System"
      }
    ]
  }
}
