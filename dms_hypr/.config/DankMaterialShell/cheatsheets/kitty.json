        "action": "New tab with directory",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Tab",
        "desc": "Next tab",
        "action": "Next tab",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Tab",
        "desc": "Previous tab",
        "action": "Previous tab",
        "source": "kitty"
      },
      {
        "key": "Alt+1",
        "desc": "Go to specific tab index",
        "action": "Go to specific tab index",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Page_Down",
        "desc": "Move tab forward",
        "action": "Move tab forward",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Page_Up",
        "desc": "Move tab backward",
        "action": "Move tab backward",
        "source": "kitty"
      }
