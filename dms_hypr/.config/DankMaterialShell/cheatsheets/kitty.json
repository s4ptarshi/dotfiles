        "action": "New vertical split",
        "source": "kitty"
      },
      {
        "key": "Alt+Minus",
        "desc": "New horizontal split",
        "action": "New horizontal split",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Q",
        "desc": "Close window",
        "action": "Close window",
        "source": "kitty"
      },
      {
        "key": "Alt+H",
        "desc": "Navigate between panes",
        "action": "Navigate between panes",
        "source": "kitty"
      },
      {
        "key": "Ctrl+1",
        "desc": "Focus specific window",
        "action": "Focus specific window",
        "source": "kitty"
      },
      {
        "key": "Alt+Shift+H",
