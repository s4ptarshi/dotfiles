{
  "title": "Kitty Keybinds",
  "provider": "kitty",
  "binds": {
    "Scrolling": [
      {
        "key": "Page_Up",
        "desc": "Scroll page up",
        "action": "Scroll page up",
        "source": "kitty"
      },
      {
        "key": "Page_Down",
        "desc": "Scroll page down",
        "action": "Scroll page down",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Page_Up",
        "desc": "Scroll line up",
        "action": "Scroll line up",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Page_Down",
        "desc": "Scroll line down",
        "action": "Scroll line down",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+Home",
        "desc": "Scroll to top",
        "action": "Scroll to top",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+End",
        "desc": "Scroll to bottom",
        "action": "Scroll to bottom",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Alt+Home",
        "desc": "Scroll to previous prompt",
        "action": "Scroll to previous prompt",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Alt+End",
        "desc": "Scroll to next prompt",
        "action": "Scroll to next prompt",
        "source": "kitty"
      }
    ],
    "Tabs Management": [
      {
        "key": "Ctrl+T",
        "desc": "New tab",
        "action": "New tab",
        "source": "kitty"
      },
      {
        "key": "Ctrl+W",
        "desc": "Close tab",
        "action": "Close tab",
        "source": "kitty"
      },
      {
        "key": "Ctrl+Shift+N",
